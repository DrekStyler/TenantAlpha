generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── User Profile ───────────────────────────────────────────────

model UserProfile {
  id            String   @id @default(cuid())
  clerkUserId   String   @unique @map("clerk_user_id")
  email         String
  name          String?
  brokerageName String?  @map("brokerage_name")
  phone         String?
  logoUrl       String?  @map("logo_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  deals       Deal[]
  savedLeases SavedLease[]
  clients     Client[]

  @@map("user_profiles")
}

// ─── Deal ───────────────────────────────────────────────────────

enum PropertyType {
  OFFICE
  RETAIL
  INDUSTRIAL
  FLEX
  OTHER
}

enum DealStatus {
  DRAFT
  CALCULATED
  EXPORTED
  ARCHIVED
}

enum DealStage {
  PROSPECTING
  REQUIREMENTS
  TOUR
  LOI
  NEGOTIATION
  UNDER_REVIEW
  EXECUTED
  DEAD
}

model Deal {
  id           String       @id @default(cuid())
  userId       String       @map("user_id")
  dealName     String       @map("deal_name")
  clientName   String?      @map("client_name")
  clientId     String?      @map("client_id")
  propertyType PropertyType @default(OFFICE) @map("property_type")
  status       DealStatus   @default(DRAFT)
  stage        DealStage    @default(PROSPECTING)
  sourceType           String       @default("MANUAL") @map("source_type") // "MANUAL" | "AI_SURVEY"
  searchLocation       String?      @map("search_location")
  searchLocationBounds Json?        @map("search_location_bounds")
  targetSF             Int?         @map("target_sf")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  user      UserProfile  @relation(fields: [userId], references: [clerkUserId])
  client    Client?      @relation(fields: [clientId], references: [id])
  options   LeaseOption[]
  aiSummary AISummary?
  memos     MemoArtifact[]

  @@index([userId])
  @@index([clientId])
  @@map("deals")
}

// ─── Lease Option ───────────────────────────────────────────────

enum EscalationType {
  FIXED_PERCENT
  CPI
}

enum FreeRentType {
  ABATED
  DEFERRED
}

enum RentStructure {
  GROSS
  NNN
  MODIFIED_GROSS
}

enum ExistingCondition {
  SHELL
  SECOND_GEN
  TURNKEY
  AS_IS
}

model LeaseOption {
  id        String @id @default(cuid())
  dealId    String @map("deal_id")
  sortOrder Int    @default(0) @map("sort_order")

  // Identification
  optionName      String       @map("option_name")
  propertyAddress String?      @map("property_address")
  propertyType    PropertyType? @map("property_type")

  // Location / Geocoding cache
  latitude          Float?    @map("latitude")
  longitude         Float?    @map("longitude")
  formattedAddress  String?   @map("formatted_address")
  walkScore         Int?      @map("walk_score")
  driveScore        Int?      @map("drive_score")
  locationFetchedAt DateTime? @map("location_fetched_at")

  // Space
  rentableSF Float  @map("rentable_sf")
  usableSF   Float? @map("usable_sf")
  loadFactor Float? @map("load_factor")

  // Term
  leaseCommencementDate DateTime? @map("lease_commencement_date")
  termMonths            Int       @map("term_months")

  // Rent
  baseRentY1        Float          @map("base_rent_y1")
  escalationType    EscalationType @default(FIXED_PERCENT) @map("escalation_type")
  escalationPercent Float          @default(3.0) @map("escalation_percent")
  cpiAssumedPercent Float?         @map("cpi_assumed_percent")

  // Free Rent
  freeRentMonths Int          @default(0) @map("free_rent_months")
  freeRentType   FreeRentType @default(ABATED) @map("free_rent_type")

  // Structure
  rentStructure RentStructure @default(GROSS) @map("rent_structure")

  // Operating Expenses
  opExPerSF      Float? @map("opex_per_sf")
  opExEscalation Float? @map("opex_escalation")
  propertyTax    Float? @map("property_tax")

  // Expense Stops
  expenseStopPerSF    Float? @map("expense_stop_per_sf")    // $/SF/yr
  baseYearOpExPerSF   Float? @map("base_year_opex_per_sf")  // $/SF/yr (base year stop)

  // Additional Costs
  parkingCostMonthly Float? @map("parking_cost_monthly")
  otherMonthlyFees   Float? @map("other_monthly_fees")
  cashAllowance      Float? @map("cash_allowance")          // $ total (moving allowance, etc.)

  // Tenant Improvements
  tiAllowance           Float?             @map("ti_allowance")
  estimatedBuildoutCost Float?             @map("estimated_buildout_cost")
  existingCondition     ExistingCondition? @map("existing_condition")

  // Financial Context
  discountRate          Float  @default(8.0) @map("discount_rate")
  annualRevenue         Float? @map("annual_revenue")
  employees             Int?
  expectedRevenueGrowth Float? @map("expected_revenue_growth")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  deal      Deal              @relation(fields: [dealId], references: [id], onDelete: Cascade)
  amenities LocationAmenity[]

  @@index([dealId])
  @@map("lease_options")
}

// ─── Location Amenity (Cached Nearby Places) ─────────────────────

model LocationAmenity {
  id             String  @id @default(cuid())
  optionId       String  @map("option_id")
  category       String  // "restaurant", "cafe", "gym", etc.
  name           String
  latitude       Float
  longitude      Float
  distanceMeters Int     @map("distance_meters")
  rating         Float?
  address        String?

  option LeaseOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@index([optionId])
  @@map("location_amenities")
}

// ─── Saved Lease (Historical Records) ───────────────────────────

model SavedLease {
  id              String        @id @default(cuid())
  userId          String        @map("user_id")
  leaseName       String        @map("lease_name")
  tenantName      String?       @map("tenant_name")
  propertyAddress String?       @map("property_address")
  propertyType    PropertyType? @map("property_type")
  rentableSF      Float         @map("rentable_sf")
  termMonths      Int           @map("term_months")
  baseRentY1      Float         @map("base_rent_y1")
  escalationType  EscalationType @default(FIXED_PERCENT) @map("escalation_type")
  escalationPercent Float       @default(3.0) @map("escalation_percent")
  rentStructure   RentStructure @default(GROSS) @map("rent_structure")
  tiAllowance     Float?        @map("ti_allowance")
  signedDate      DateTime?     @map("signed_date")
  notes           String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user UserProfile @relation(fields: [userId], references: [clerkUserId])

  @@index([userId])
  @@map("saved_leases")
}

// ─── Client ──────────────────────────────────────────────────────

enum ClientSize {
  SOLO         // 1 person
  SMALL        // 2-10
  MEDIUM       // 11-50
  LARGE        // 51-200
  ENTERPRISE   // 200+
}

enum IndustryType {
  MEDICAL
  LEGAL
  AEROSPACE_DEFENSE
  TECH
  FINANCIAL
  GENERAL_OFFICE
}

model Client {
  id                String      @id @default(cuid())
  userId            String      @map("user_id")
  clientClerkUserId String?     @unique @map("client_clerk_user_id") // client's own Clerk account
  token             String      @unique @default(cuid()) // public questionnaire link token
  tokenExpiresAt    DateTime?   @map("token_expires_at")  // token TTL — null = no expiry (legacy)

  // Basic info
  name          String
  company       String?
  email         String?
  phone         String?
  industry      String?
  companySize   ClientSize? @map("company_size")

  // Survey mode: "STATIC" (default) or "AI_AGENT"
  surveyMode    String      @default("STATIC") @map("survey_mode")

  // Questionnaire answers (null = not yet submitted)
  currentHeadcount       Int?    @map("current_headcount")
  projectedHeadcount12mo Int?    @map("projected_headcount_12mo")
  revenuePerEmployee     Float?  @map("revenue_per_employee")
  currentAnnualRevenue   Float?  @map("current_annual_revenue")
  projectedRevenueGrowth Float?  @map("projected_revenue_growth")
  sfPerEmployee          Float?  @map("sf_per_employee")
  criticalAmenities      String? @map("critical_amenities") // JSON array as string
  expansionTimeline      String? @map("expansion_timeline")
  budgetConstraint       Float?  @map("budget_constraint")
  primaryGoal            String? @map("primary_goal")

  questionnaireCompletedAt DateTime? @map("questionnaire_completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user            UserProfile      @relation(fields: [userId], references: [clerkUserId])
  deals           Deal[]
  industryProfile IndustryProfile?
  surveySession   SurveySession?

  @@index([userId])
  @@index([token])
  @@map("clients")
}

// ─── Industry Profile (AI Survey ROI Data) ───────────────────────

model IndustryProfile {
  id             String       @id @default(cuid())
  clientId       String       @unique @map("client_id")
  industryType   IndustryType @map("industry_type")

  // Flexible JSON for industry-specific fields
  // Medical: { providers, examRooms, visitsPerProviderDay, reimbursementPerVisit, payerMix, cycleTimeMinutes, specialtyType }
  // Legal: { partners, associates, paralegals, billableHourTarget, realizationRate, blendedBillingRate, practiceAreas }
  // Aerospace: { scifRequired, facilityCleared, clearanceLevel, itarCompliant, cmmcLevel, powerRequirementKW, ceilingHeightFt }
  // Tech: { engineers, productTeams, deploymentFrequency, hybridWorkPercent }
  // Financial: { advisors, aum, clientMeetingsPerWeek, complianceLevel }
  industryInputs Json         @map("industry_inputs")

  // Computed ROI outputs (cached after calculation)
  roiOutputs     Json?        @map("roi_outputs")

  // ROI calculation inputs (for showing formulas with actual numbers)
  roiCalcInputs  Json?        @map("roi_calc_inputs")

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("industry_profiles")
}

// ─── Survey Session (AI Conversation State) ──────────────────────

model SurveySession {
  id            String   @id @default(cuid())
  clientId      String   @unique @map("client_id")
  token         String   // matches Client.token for lookup

  // Conversation history (array of {role, content, timestamp} objects)
  messages      Json     @default("[]")

  // Extracted structured data accumulated as AI parses answers
  extractedData Json     @default("{}") @map("extracted_data")

  // Survey progress: INDUSTRY_DETECTION -> INDUSTRY_QUESTIONS -> LEASE_PREFERENCES -> REVIEW -> COMPLETED
  phase         String   @default("INDUSTRY_DETECTION")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("survey_sessions")
}

// ─── Memo Artifact (DOCX Generation Records) ───────────────────

model MemoArtifact {
  id              String   @id @default(cuid())
  dealId          String   @map("deal_id")
  userId          String   @map("user_id")
  memoType        String   @map("memo_type")         // IC_DECISION_MEMO, MARKET_BRIEF, etc.
  audience        String                               // CEO, CFO, COO, IC
  tone            String                               // BANK_STYLE, CONCISE, NARRATIVE
  includeSections String[] @map("include_sections")   // array of section IDs
  inputSnapshot   Json     @map("input_snapshot")     // frozen deal + options at generation time
  sections        Json?                                // generated sections output
  promptVersion   String   @map("prompt_version")     // version tag for reproducibility
  modelVersion    String?  @map("model_version")      // AI model used
  errorMessage    String?  @map("error_message")
  generatedAt     DateTime @default(now()) @map("generated_at")

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([userId])
  @@map("memo_artifacts")
}

// ─── AI Summary ─────────────────────────────────────────────────

model AISummary {
  id              String   @id @default(cuid())
  dealId          String   @unique @map("deal_id")
  summaryText     String   @map("summary_text") @db.Text
  recommendations String?  @db.Text
  generatedAt     DateTime @default(now()) @map("generated_at")

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@map("ai_summaries")
}
